FROM nginx:alpine

# Nginx konfigürasyonunu kopyala
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Statik web dosyalarını kopyala
COPY index.html /usr/share/nginx/html/
COPY BspTree.js /usr/share/nginx/html/
COPY EnemyAI.js /usr/share/nginx/html/
COPY PhysicsEngine.js /usr/share/nginx/html/
COPY game.js /usr/share/nginx/html/
COPY player.js /usr/share/nginx/html/
COPY vision.js /usr/share/nginx/html/
